# GCP
GCP_PROJECT_ID=
GCP_REGION=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/local-sa-key.json

# LLM — changer LLM_PROVIDER + LLM_MODEL pour swapper le modèle
LLM_PROVIDER=anthropic  # anthropic | openai | google
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...  # fallback optionnel

# Embeddings (Vertex AI via google-genai SDK)
EMBEDDING_MODEL=text-embedding-005

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=offerlens-dev

# Gmail
GMAIL_RECIPIENT=
GMAIL_OAUTH_TOKEN_PATH=/path/to/token.json

# Gmail OAuth2 — headless (Cloud Run)
# Remplir ces trois vars pour éviter token.json en production.
# En local, laisser vides : le flow interactif (token.json) est utilisé.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Firestore (laisser vide pour pointer sur le vrai Firestore)
FIRESTORE_EMULATOR_HOST=
